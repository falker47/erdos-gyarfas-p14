{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:erdos-gyarfas-p14:schema:benchmark-result:1.0",
  "title": "Engineering benchmark result",
  "description": "Measured process metadata for an engineering benchmark. A conforming result is not mathematical evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "classification",
    "case_id",
    "project_revision",
    "project_commit",
    "working_tree_status",
    "case_definition_sha256",
    "upstream_commit",
    "executable_path",
    "executable_sha256",
    "command",
    "k",
    "compiler",
    "compiler_flags",
    "environment",
    "operating_system",
    "architecture",
    "cpu_count",
    "thread_count",
    "started_at_utc",
    "finished_at_utc",
    "wall_time_seconds",
    "cpu_time_seconds",
    "peak_memory_bytes",
    "exit_code",
    "termination_reason",
    "stdout_path",
    "stderr_path",
    "stdout_sha256",
    "stderr_sha256",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "artifact_kind": {
      "const": "engineering_benchmark"
    },
    "classification": {
      "const": "EMPIRICAL_OBSERVATION"
    },
    "case_id": {
      "$ref": "#/$defs/identifier"
    },
    "project_revision": {
      "type": "string",
      "minLength": 1
    },
    "project_commit": {
      "oneOf": [
        {
          "$ref": "#/$defs/git_commit"
        },
        {
          "type": "null"
        }
      ]
    },
    "working_tree_status": {
      "enum": [
        "clean",
        "dirty",
        "unborn",
        "not-a-git-repository",
        "unknown"
      ]
    },
    "case_definition_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "upstream_commit": {
      "$ref": "#/$defs/git_commit"
    },
    "executable_path": {
      "$ref": "#/$defs/repository_path"
    },
    "executable_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "k": {
      "type": "integer",
      "minimum": 1
    },
    "compiler": {
      "type": "string",
      "minLength": 1
    },
    "compiler_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "operating_system": {
      "type": "string",
      "minLength": 1
    },
    "architecture": {
      "type": "string",
      "minLength": 1
    },
    "cpu_count": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "thread_count": {
      "type": "integer",
      "minimum": 1
    },
    "started_at_utc": {
      "$ref": "#/$defs/timestamp"
    },
    "finished_at_utc": {
      "$ref": "#/$defs/timestamp"
    },
    "wall_time_seconds": {
      "type": "number",
      "minimum": 0
    },
    "cpu_time_seconds": {
      "oneOf": [
        {
          "type": "number",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "peak_memory_bytes": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "termination_reason": {
      "enum": [
        "exited",
        "timeout",
        "spawn-error",
        "signal"
      ]
    },
    "stdout_path": {
      "$ref": "#/$defs/repository_path"
    },
    "stderr_path": {
      "$ref": "#/$defs/repository_path"
    },
    "stdout_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "stderr_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "git_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "repository_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_.@+:/-]+$"
    }
  }
}
