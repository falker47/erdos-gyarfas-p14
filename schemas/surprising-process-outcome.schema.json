{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:erdos-gyarfas-p14:schema:surprising-process-outcome:1.0",
  "title": "Surprising tiny process outcome and bounded inspection records",
  "description": "Byte-preserving EMPIRICAL_OBSERVATION records for nonordinary tiny upstream outcomes and their separate bounded inspection. Conformance is not counterexample acceptance or mathematical evidence.",
  "oneOf": [
    {
      "$ref": "#/$defs/outcome_record"
    },
    {
      "$ref": "#/$defs/inspection_record"
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "git_commit_or_null": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "artifact_basename": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
    },
    "frozen_stream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "byte_length",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/artifact_basename"
        },
        "byte_length": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "captured_stream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base64",
        "byte_length",
        "sha256"
      ],
      "properties": {
        "base64": {
          "type": "string"
        },
        "byte_length": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "outcome_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "artifact_kind",
        "classification",
        "k",
        "command",
        "executable_path",
        "executable_sha256",
        "project_commit",
        "project_revision",
        "upstream_commit",
        "termination_reason",
        "exit_code",
        "launcher_error",
        "upstream_timeout_seconds",
        "stdout",
        "stderr",
        "inspection_initial_status",
        "inspection_artifact_path",
        "inspection_timeout_seconds",
        "limitations"
      ],
      "properties": {
        "schema_version": {
          "const": "1.0"
        },
        "artifact_kind": {
          "const": "surprising_process_outcome"
        },
        "classification": {
          "const": "EMPIRICAL_OBSERVATION"
        },
        "k": {
          "type": "integer",
          "minimum": 1
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "executable_path": {
          "type": "string",
          "minLength": 1
        },
        "executable_sha256": {
          "oneOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        },
        "project_commit": {
          "$ref": "#/$defs/git_commit_or_null"
        },
        "project_revision": {
          "type": "string",
          "minLength": 1
        },
        "upstream_commit": {
          "$ref": "#/$defs/git_commit_or_null"
        },
        "termination_reason": {
          "enum": [
            "exited",
            "signal",
            "timeout",
            "spawn-error"
          ]
        },
        "exit_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "launcher_error": {
          "type": [
            "string",
            "null"
          ]
        },
        "upstream_timeout_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "stdout": {
          "$ref": "#/$defs/frozen_stream"
        },
        "stderr": {
          "$ref": "#/$defs/frozen_stream"
        },
        "inspection_initial_status": {
          "enum": [
            "not_started",
            "not_applicable"
          ]
        },
        "inspection_artifact_path": {
          "$ref": "#/$defs/artifact_basename"
        },
        "inspection_timeout_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "limitations": {
          "$ref": "#/$defs/limitations"
        }
      },
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "termination_reason": {
                  "const": "exited"
                },
                "exit_code": {
                  "type": "integer",
                  "minimum": 1
                },
                "launcher_error": {
                  "type": "null"
                }
              }
            },
            {
              "properties": {
                "termination_reason": {
                  "const": "signal"
                },
                "exit_code": {
                  "type": "integer",
                  "maximum": -1
                },
                "launcher_error": {
                  "type": "null"
                }
              }
            },
            {
              "properties": {
                "termination_reason": {
                  "const": "timeout"
                },
                "exit_code": {
                  "type": "null"
                },
                "launcher_error": {
                  "type": "null"
                }
              }
            },
            {
              "properties": {
                "termination_reason": {
                  "const": "spawn-error"
                },
                "exit_code": {
                  "type": "null"
                },
                "launcher_error": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          ]
        },
        {
          "if": {
            "properties": {
              "termination_reason": {
                "const": "exited"
              },
              "exit_code": {
                "const": 100
              }
            }
          },
          "then": {
            "properties": {
              "inspection_initial_status": {
                "const": "not_started"
              }
            }
          },
          "else": {
            "properties": {
              "inspection_initial_status": {
                "const": "not_applicable"
              }
            }
          }
        }
      ]
    },
    "inspection_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parse_succeeded",
        "parse_error",
        "canonical_graph_serialization",
        "canonical_graph_sha256",
        "checks",
        "all_candidate_predicates_passed"
      ],
      "properties": {
        "parse_succeeded": {
          "type": "boolean"
        },
        "parse_error": {
          "oneOf": [
            {
              "$ref": "#/$defs/error"
            },
            {
              "type": "null"
            }
          ]
        },
        "canonical_graph_serialization": {
          "type": [
            "string",
            "null"
          ]
        },
        "canonical_graph_sha256": {
          "oneOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        },
        "checks": {
          "type": [
            "object",
            "null"
          ],
          "minProperties": 1
        },
        "all_candidate_predicates_passed": {
          "type": [
            "boolean",
            "null"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "parse_succeeded": {
                "const": true
              }
            },
            "required": [
              "parse_succeeded"
            ]
          },
          "then": {
            "properties": {
              "parse_error": {
                "type": "null"
              },
              "canonical_graph_serialization": {
                "type": "string",
                "minLength": 1
              },
              "canonical_graph_sha256": {
                "$ref": "#/$defs/sha256"
              },
              "checks": {
                "type": "object",
                "minProperties": 1
              },
              "all_candidate_predicates_passed": {
                "type": "boolean"
              }
            }
          },
          "else": {
            "properties": {
              "parse_error": {
                "$ref": "#/$defs/error"
              },
              "canonical_graph_serialization": {
                "type": "null"
              },
              "canonical_graph_sha256": {
                "type": "null"
              },
              "checks": {
                "type": "null"
              },
              "all_candidate_predicates_passed": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "inspector_process": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exit_code",
        "stdout",
        "stderr"
      ],
      "properties": {
        "exit_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "stdout": {
          "$ref": "#/$defs/captured_stream"
        },
        "stderr": {
          "$ref": "#/$defs/captured_stream"
        }
      }
    },
    "inspection_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "artifact_kind",
        "classification",
        "source_outcome_path",
        "source_outcome_sha256",
        "source_outcome_preserved",
        "k",
        "status",
        "inspection_timeout_seconds",
        "source_streams",
        "source_streams_preserved",
        "result",
        "error",
        "inspector_process",
        "limitations"
      ],
      "properties": {
        "schema_version": {
          "const": "1.0"
        },
        "artifact_kind": {
          "const": "surprising_process_outcome_inspection"
        },
        "classification": {
          "const": "EMPIRICAL_OBSERVATION"
        },
        "source_outcome_path": {
          "$ref": "#/$defs/artifact_basename"
        },
        "source_outcome_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "source_outcome_preserved": {
          "type": "boolean"
        },
        "k": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "enum": [
            "completed",
            "timeout",
            "error"
          ]
        },
        "inspection_timeout_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "source_streams": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "stdout",
            "stderr"
          ],
          "properties": {
            "stdout": {
              "$ref": "#/$defs/frozen_stream"
            },
            "stderr": {
              "$ref": "#/$defs/frozen_stream"
            }
          }
        },
        "source_streams_preserved": {
          "type": "boolean"
        },
        "result": {
          "oneOf": [
            {
              "$ref": "#/$defs/inspection_result"
            },
            {
              "type": "null"
            }
          ]
        },
        "error": {
          "oneOf": [
            {
              "$ref": "#/$defs/error"
            },
            {
              "type": "null"
            }
          ]
        },
        "inspector_process": {
          "oneOf": [
            {
              "$ref": "#/$defs/inspector_process"
            },
            {
              "type": "null"
            }
          ]
        },
        "limitations": {
          "$ref": "#/$defs/limitations"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "completed"
              }
            }
          },
          "then": {
            "properties": {
              "result": {
                "$ref": "#/$defs/inspection_result"
              },
              "error": {
                "type": "null"
              },
              "inspector_process": {
                "type": "null"
              },
              "source_outcome_preserved": {
                "const": true
              },
              "source_streams_preserved": {
                "const": true
              }
            }
          },
          "else": {
            "properties": {
              "result": {
                "type": "null"
              },
              "error": {
                "$ref": "#/$defs/error"
              },
              "inspector_process": {
                "$ref": "#/$defs/inspector_process"
              }
            }
          }
        }
      ]
    }
  }
}
