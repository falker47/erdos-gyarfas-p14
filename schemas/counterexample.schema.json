{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:erdos-gyarfas-p14:schema:counterexample:1.0",
  "title": "Canonical graph and counterexample artifact",
  "description": "Syntactic envelope for a candidate counterexample. Schema validity does not establish graph simplicity, canonical ordering, hash correctness, or either counterexample predicate.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "graph_id",
    "vertex_count",
    "vertices",
    "edges",
    "graph_sha256",
    "source_task",
    "source_project_commit",
    "generator_command",
    "generator_environment",
    "target_claim",
    "k",
    "search_mode",
    "verification_status"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "graph_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "vertex_count": {
      "type": "integer",
      "minimum": 0
    },
    "vertices": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/vertex_id"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "prefixItems": [
          {
            "$ref": "#/$defs/vertex_id"
          },
          {
            "$ref": "#/$defs/vertex_id"
          }
        ],
        "items": false
      }
    },
    "graph_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "source_task": {
      "type": "string",
      "pattern": "^TASK-[0-9]{8}__[a-z0-9_]+$"
    },
    "source_project_commit": {
      "oneOf": [
        {
          "$ref": "#/$defs/git_commit"
        },
        {
          "type": "null"
        }
      ]
    },
    "generator_command": {
      "$ref": "#/$defs/command"
    },
    "generator_environment": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "integer",
          "boolean",
          "null"
        ]
      }
    },
    "target_claim": {
      "enum": [
        "EG-P14",
        "EG-P13-C4C8"
      ]
    },
    "k": {
      "enum": [
        13,
        14
      ]
    },
    "search_mode": {
      "enum": [
        "p14-power2",
        "p13-c4c8"
      ]
    },
    "verification_status": {
      "enum": [
        "unverified",
        "generator-only",
        "independent-verification-failed",
        "independently-verified"
      ]
    },
    "verifier": {
      "oneOf": [
        {
          "$ref": "#/$defs/verifier"
        },
        {
          "type": "null"
        }
      ]
    },
    "limitations": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "target_claim": {
            "const": "EG-P14"
          }
        },
        "required": [
          "target_claim"
        ]
      },
      "then": {
        "properties": {
          "k": {
            "const": 14
          },
          "search_mode": {
            "const": "p14-power2"
          }
        }
      },
      "else": {
        "properties": {
          "k": {
            "const": 13
          },
          "search_mode": {
            "const": "p13-c4c8"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "verification_status": {
            "const": "independently-verified"
          }
        },
        "required": [
          "verification_status"
        ]
      },
      "then": {
        "required": [
          "verifier"
        ],
        "properties": {
          "verifier": {
            "$ref": "#/$defs/verifier"
          }
        }
      }
    }
  ],
  "$defs": {
    "vertex_id": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
        }
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "git_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "command",
        "result"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "executable_sha256": {
          "oneOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        },
        "command": {
          "$ref": "#/$defs/command"
        },
        "result": {
          "enum": [
            "passed",
            "failed",
            "error"
          ]
        }
      }
    }
  }
}
