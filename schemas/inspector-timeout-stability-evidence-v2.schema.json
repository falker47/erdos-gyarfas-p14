        "untracked": { "$ref": "#/$defs/git_probe" },
        "ignored": { "$ref": "#/$defs/git_probe" },
        "staged": { "$ref": "#/$defs/git_probe" }
      }
    },
    "path_array": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/repository_path" }
    },
    "tracked_modified_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "index_status", "worktree_status"],
      "properties": {
        "path": { "$ref": "#/$defs/repository_path" },
        "index_status": { "type": "string", "minLength": 1, "maxLength": 1 },
        "worktree_status": { "type": "string", "minLength": 1, "maxLength": 1 }
      }
    },
    "staged_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "index_status"],
      "properties": {
        "path": { "$ref": "#/$defs/repository_path" },
