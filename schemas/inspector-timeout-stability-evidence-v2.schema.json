    "pytest_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parsed", "passed", "failed", "errors", "skipped", "xfailed", "xpassed", "diagnostic"],
      "properties": {
        "parsed": { "type": "boolean" },
        "passed": { "$ref": "#/$defs/nullable_nonnegative_integer" },
        "failed": { "$ref": "#/$defs/nullable_nonnegative_integer" },
        "errors": { "$ref": "#/$defs/nullable_nonnegative_integer" },
        "skipped": { "$ref": "#/$defs/nullable_nonnegative_integer" },
