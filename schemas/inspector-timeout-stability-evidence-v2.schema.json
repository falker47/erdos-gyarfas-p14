{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:erdos-gyarfas-p14:schema:inspector-timeout-stability-evidence-v2:2.0",
  "title": "Inspector timeout stability evidence v2",
  "description": "Closed-world machine-readable bounded V1 engineering-test evidence. Format version 2 binds collection and every pytest subprocess to recorded source and worktree identities; it is not mathematical evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "classification",
    "task_id",
    "repository",
    "review_base_commit",
    "task_start_head",
    "execution_project_revision",
    "execution_started_at_utc",
    "execution_finished_at_utc",
    "completed",
    "source_files",
    "non_execution_task_paths",
    "environment",
    "expected_plan",
    "report_persistence",
    "collection_identity",
    "worktree_snapshots",
    "runs",
    "summary",
    "cleanup",
    "limitations"
  ],
  "properties": {
    "schema_version": { "const": "2.0" },
    "artifact_kind": { "const": "inspector_timeout_stability_evidence" },
    "classification": { "const": "EMPIRICAL_OBSERVATION" },
    "task_id": { "const": "TASK-20260720__bind_stability_evidence_to_exact_worktree" },
    "repository": { "const": "falker47/erdos-gyarfas-p14" },
    "review_base_commit": { "const": "a7066e70b92d80be2d1772127f329c24222c1b41" },
    "task_start_head": { "const": "b1eb792a2a771485f37979cd932303f14ab52f56" },
    "execution_project_revision": { "$ref": "#/$defs/execution_project_revision" },
    "execution_started_at_utc": { "$ref": "#/$defs/timestamp" },
    "execution_finished_at_utc": { "$ref": "#/$defs/nullable_timestamp" },
    "completed": { "type": "boolean" },
    "source_files": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/source_file" }
    },
    "non_execution_task_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/repository_path" }
    },
    "environment": { "$ref": "#/$defs/environment" },
    "expected_plan": { "$ref": "#/$defs/expected_plan" },
    "report_persistence": { "$ref": "#/$defs/report_persistence" },
    "collection_identity": { "$ref": "#/$defs/collection_identity" },
    "worktree_snapshots": {
      "type": "array",
      "minItems": 1,
      "maxItems": 58,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/worktree_snapshot" }
    },
    "runs": {
      "type": "array",
      "maxItems": 27,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/run_record" }
    },
    "summary": { "$ref": "#/$defs/summary" },
    "cleanup": { "$ref": "#/$defs/cleanup" },
    "limitations": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9](?:\\.[0-9]{1,9})?Z$"
    },
    "nullable_timestamp": {
      "oneOf": [
        { "$ref": "#/$defs/timestamp" },
        { "type": "null" }
      ]
    },
    "nullable_nonempty_string": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "null" }
      ]
    },
    "nullable_nonnegative_integer": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "null" }
      ]
    },
    "repository_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*[\\u0000-\\u001F\\u007F])[^/]+(?:/[^/]+)*$"
    },
    "captured_stream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base64", "byte_length", "sha256"],
      "properties": {
        "base64": {
          "type": "string",
          "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
        },
        "byte_length": { "type": "integer", "minimum": 0 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "file_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effective_value",
        "resolved_path",
        "readable",
        "byte_length",
        "sha256",
        "limitation"
      ],
      "properties": {
        "effective_value": { "type": "string", "minLength": 1 },
        "resolved_path": { "$ref": "#/$defs/nullable_nonempty_string" },
        "readable": { "type": "boolean" },
        "byte_length": { "$ref": "#/$defs/nullable_nonnegative_integer" },
        "sha256": {
          "oneOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        },
        "limitation": { "$ref": "#/$defs/nullable_nonempty_string" }
      }
    },
    "execution_project_revision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "fingerprint_kind",
        "fingerprint_sha256",
        "fingerprint_scope",
        "worktree_identity_sha256"
      ],
      "properties": {
        "state": { "const": "dirty" },
        "fingerprint_kind": { "const": "canonical_source_inventory_v2" },
        "fingerprint_sha256": {
          "oneOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        },
        "fingerprint_scope": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/repository_path" }
        },
        "worktree_identity_sha256": {
          "oneOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        }
      }
    },
    "source_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "byte_length", "sha256", "origin"],
      "properties": {
        "path": { "$ref": "#/$defs/repository_path" },
        "byte_length": { "type": "integer", "minimum": 0 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "origin": { "enum": ["tracked", "untracked"] }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "python_version",
        "python_implementation",
        "python_executable",
        "git_executable",
        "operating_system",
        "architecture",
        "machine_identifier",
        "processor_identifier",
        "cpu_count",
        "working_directory",
        "tool_overrides",
        "limitations"
      ],
      "properties": {
        "python_version": { "type": "string", "minLength": 1 },
        "python_implementation": { "type": "string", "minLength": 1 },
        "python_executable": { "$ref": "#/$defs/file_identity" },
        "git_executable": { "$ref": "#/$defs/file_identity" },
        "operating_system": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "machine_identifier": { "$ref": "#/$defs/nullable_nonempty_string" },
        "processor_identifier": { "$ref": "#/$defs/nullable_nonempty_string" },
        "cpu_count": { "$ref": "#/$defs/nullable_nonnegative_integer" },
        "working_directory": { "type": "string", "minLength": 1 },
        "tool_overrides": {
          "type": "object",
          "additionalProperties": false,
          "required": ["EG_CMAKE", "EG_CXX", "EG_NINJA", "EG_MAKE"],
          "properties": {
            "EG_CMAKE": { "$ref": "#/$defs/file_identity" },
            "EG_CXX": { "$ref": "#/$defs/file_identity" },
            "EG_NINJA": { "$ref": "#/$defs/file_identity" },
            "EG_MAKE": { "$ref": "#/$defs/file_identity" }
          }
        },
        "limitations": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "expected_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection_preflight_runs",
        "focused_runs",
        "full_suite_runs",
        "serial",
        "retries",
        "stop_on_first_failure"
      ],
      "properties": {
        "collection_preflight_runs": { "const": 2 },
        "focused_runs": { "const": 25 },
        "full_suite_runs": { "const": 2 },
        "serial": { "const": true },
        "retries": { "const": 0 },
        "stop_on_first_failure": { "const": true }
      }
    },
    "report_persistence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_path",
        "temporary_path",
        "initial_write_mode",
        "replacement_mode",
        "fsync_file",
        "atomic_replace",
        "temporary_absent_at_finish"
      ],
      "properties": {
        "report_path": { "$ref": "#/$defs/repository_path" },
        "temporary_path": { "$ref": "#/$defs/repository_path" },
        "initial_write_mode": { "const": "same_directory_temp_then_replace" },
        "replacement_mode": { "const": "same_directory_temp_then_replace" },
        "fsync_file": { "const": true },
        "atomic_replace": { "const": true },
        "temporary_absent_at_finish": { "type": "boolean" }
      }
    },
    "environment_overrides": {
      "type": "object",
      "additionalProperties": false,
      "required": ["PYTHONPYCACHEPREFIX", "PYTEST_DISABLE_PLUGIN_AUTOLOAD"],
      "properties": {
        "PYTHONPYCACHEPREFIX": { "type": "string", "minLength": 1 },
        "PYTEST_DISABLE_PLUGIN_AUTOLOAD": { "const": "1" },
        "EG_CMAKE": { "type": "string", "minLength": 1 },
        "EG_CXX": { "type": "string", "minLength": 1 },
        "EG_NINJA": { "type": "string", "minLength": 1 },
        "EG_MAKE": { "type": "string", "minLength": 1 }
      }
    },
    "git_probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["argv", "exit_code", "stdout", "stderr"],
