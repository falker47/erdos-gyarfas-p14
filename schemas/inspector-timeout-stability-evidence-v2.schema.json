        "untracked",
        "ignored_task_basetemps",
        "ignored_other",
        "task_owned_non_execution_paths",
        "execution_input_paths",
        "unexpected_paths"
      ],
      "properties": {
        "tracked_clean": { "$ref": "#/$defs/path_array" },
