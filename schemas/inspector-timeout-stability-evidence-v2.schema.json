        "wall_time_ns",
        "exit_code",
        "stdout",
        "stderr",
        "before_snapshot_sequence",
        "after_snapshot_sequence",
        "node_ids",
        "collected_count",
        "status",
        "diagnostic"
      ],
      "properties": {
