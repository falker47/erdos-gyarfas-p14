    },
    "collection_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "records",
        "focused_node_ids",
        "full_suite_node_ids",
        "focused_count",
        "full_suite_count",
        "digest_kind",
        "digest_sha256",
        "diagnostic"
      ],
      "properties": {
        "status": { "enum": ["pending", "completed", "failed", "interrupted"] },
        "records": {
          "type": "array",
          "maxItems": 2,
          "uniqueItems": true,
