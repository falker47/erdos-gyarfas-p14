          "oneOf": [
            { "$ref": "#/$defs/worktree_parsed" },
            { "type": "null" }
          ]
        },
        "normalized_sha256": {
          "oneOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        },
        "execution_state_sha256": {
          "oneOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        },
        "source_fingerprint_sha256": {
          "oneOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        },
        "accepted": { "type": "boolean" },
        "diagnostic": { "$ref": "#/$defs/nullable_nonempty_string" }
      }
    },
    "task_status_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "exists", "kind", "symlink"],
      "properties": {
        "path": { "const": "ops/TASK-20260720__bind_stability_evidence_to_exact_worktree/TASK_STATUS.md" },
