    "run_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "process_sequence",
        "sequence",
        "phase",
        "phase_index",
        "argv",
        "working_directory",
        "basetemp_path",
        "environment_overrides",
        "started_at_utc",
        "finished_at_utc",
        "wall_time_ns",
        "exit_code",
        "stdout",
        "stderr",
        "pytest_summary",
        "expected_pass_count",
