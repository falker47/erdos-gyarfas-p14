        },
        "untracked": { "$ref": "#/$defs/path_array" },
        "ignored_task_basetemps": { "$ref": "#/$defs/path_array" },
        "ignored_other": { "$ref": "#/$defs/path_array" },
        "task_owned_non_execution_paths": { "$ref": "#/$defs/path_array" },
