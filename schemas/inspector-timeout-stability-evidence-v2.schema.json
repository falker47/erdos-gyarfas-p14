        "argv": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "working_directory": { "type": "string", "minLength": 1 },
        "basetemp_path": { "$ref": "#/$defs/repository_path" },
        "environment_overrides": { "$ref": "#/$defs/environment_overrides" },
